modules = ["nodejs-24", "postgresql-16"]

  [[artifacts]]
  id = "artifacts/api-server"

  [[artifacts]]
  id = "artifacts/mockup-sandbox"

  [deployment]
  router = "application"
  deploymentTarget = "autoscale"
  run = ["node", "artifacts/api-server/dist/index.cjs"]

  [deployment.postBuild]
  args = ["pnpm", "store", "prune"]
  env = { "CI" = "true" }

  [workflows]
  runButton = "Project"

  [[workflows.workflow]]
  name = "Project"
  mode = "parallel"
  author = "agent"

  [[workflows.workflow.tasks]]
  task = "workflow.run"
  args = "Start application"

  [[workflows.workflow]]
  name = "Start application"
  author = "agent"

  [[workflows.workflow.tasks]]
  task = "shell.exec"
  args = "PORT=3000 pnpm --filter @workspace/api-server run dev & PORT=5173 BASE_PATH=/ pnpm --filter @workspace/fitness-app run dev"
  waitForPort = 5173

  [workflows.workflow.metadata]
  outputType = "webview"

  [agent]
  stack = "PNPM_WORKSPACE"
expertMode = true

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000

  [nix]
  channel = "stable-25_05"

[userenv]

[userenv.shared]
