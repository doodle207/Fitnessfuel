FROM node:22-alpine
RUN npm install -g pnpm
WORKDIR /app
COPY . .
RUN sed -i '/@replit/d' artifacts/fitness-app/package.json
RUN sed -i '/@workspace\/replit/d' artifacts/fitness-app/package.json
WORKDIR /app/artifacts/fitness-app
RUN pnpm install --no-frozen-lockfile
RUN pnpm build
RUN npm install -g serve
CMD ["serve", "-s", "dist", "-l", "3000"]
