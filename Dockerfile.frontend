FROM node:22-alpine
RUN npm install -g pnpm
WORKDIR /app
COPY artifacts/fitness-app/package.json .
COPY artifacts/fitness-app/pnpm-lock.yaml* .
COPY pnpm-workspace.yaml .
COPY artifacts/fitness-app .
RUN sed -i 's/"@replit\/vite-plugin-cartographer[^"]*"[^,]*,\?//g' package.json
RUN pnpm install --no-frozen-lockfile --ignore-scripts
RUN pnpm build
RUN npm install -g serve
CMD ["serve", "-s", "dist", "-l", "3000"]
